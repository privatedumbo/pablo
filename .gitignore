# This repo's root IS a Hermes profile distribution. On `hermes profile install`
# everything here is copied into ~/.hermes/profiles/pablo/. Keep secrets and
# runtime state OUT of the repo.

# --- Secrets (never commit) ---
.env
.env.EXAMPLE
auth.json
mcp-tokens/

# --- Local extraction staging (raw VPS pull) ---
.pablo-extract/

# --- Hermes runtime state (regenerated on the box; not part of the package) ---
sessions/
memories/
logs/
cache/
*_cache/
audio_cache/
image_cache/
sandboxes/
shared/
pairing/
cron/output/
state.db
state.db-shm
state.db-wal
kanban.db*
channel_directory.json
gateway_state.json
gateway.lock
gateway.pid
*.lock
*.pid
*.bak.*
.update_check
.skills_prompt_snapshot.json

# --- OS / editor noise ---
.DS_Store
