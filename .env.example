# Secrets for the agent system. Copy to .env and fill in.
# .env is gitignored and must never be committed. See docs/setup/credentials.md.

# --- Hetzner (provisioning) ---
# console.hetzner.cloud -> project -> Security -> API Tokens (Read & Write)
# verify: hcloud server list
HCLOUD_TOKEN=

# --- Telegram (agent gateway) ---
# @BotFather -> /newbot (or /token); verify with the bot's getMe endpoint
TELEGRAM_BOT_TOKEN=
# @userinfobot -> your numeric id. Comma-separated for multiple users.
TELEGRAM_ALLOWED_USERS=

# --- Google Workspace MCP (gmail + calendar) ---
# Google Cloud -> APIs & Services -> Credentials -> OAuth client (confidential).
# One client authorizes both the personal and work accounts. See ADR-0004.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Note: the Nous Account credential is NOT here — it is created interactively
# with `hermes auth add nous` and stored only on the VPS at ~/.hermes/auth.json.
