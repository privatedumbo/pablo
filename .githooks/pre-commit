#!/usr/bin/env bash
# Local secret/identifier guard. Belt-and-suspenders alongside GitHub push
# protection. Enable once with:  git config core.hooksPath .githooks
# Blocks a commit if staged content looks like a secret or the VPS IP.
set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACM)"
[ -n "$staged" ] || exit 0

fail=0
flag() { printf '\033[1;31m[pre-commit] blocked:\033[0m %s\n' "$1" >&2; fail=1; }

# never commit these, regardless of .gitignore
echo "$staged" | grep -qE '(^|/)\.env$|auth\.json$|(^|/)mcp-tokens/' \
  && flag "secret file staged (.env / auth.json / mcp-tokens)"

# scan staged diff for secret-looking values and host IPs
diff="$(git diff --cached -U0 -- $staged || true)"
echo "$diff" | grep -qiE '^\+.*(bot[0-9]{6,}:[A-Za-z0-9_-]{30,}|AIza[0-9A-Za-z_-]{30,}|-----BEGIN [A-Z ]*PRIVATE KEY-----|ghp_[A-Za-z0-9]{30,})' \
  && flag "possible secret value in staged diff"
# public VPS IPs (allow loopback 127.0.0.1 and link-local)
echo "$diff" | grep -E '^\+' | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' \
  | grep -vE '^(127\.|0\.0\.0\.0|255\.|169\.254\.)' | grep -q . \
  && flag "a public IP address is staged — scrub host IPs"

if [ "$fail" -ne 0 ]; then
  echo "[pre-commit] commit aborted. Override (not recommended): git commit --no-verify" >&2
  exit 1
fi
